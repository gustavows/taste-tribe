
@model IEnumerable<tastetribe.Models.Review>
@{
}
<h1 class="mt-4">🗑️ Select Review to Delete</h1>
<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>ID</th>
            <th>User</th>
            <th>Restaurant</th>
            <th>Dish</th>
            <th>Rating</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.ReviewId</td>
                <td>@(r.User?.FirstName ?? "-")</td>
                <td>@(r.Restaurant?.Name ?? "-")</td>
                <td>@(r.Dish?.Name ?? "-")</td>
                <td>@r.Rating</td>
                <td>
                    <form asp-action="DeleteConfirmed" asp-route-id="@r.ReviewId" method="post" onsubmit="return confirm('Delete this review?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@r.ReviewId" />
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

