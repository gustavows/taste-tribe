@using System.Text.Json

@{
    ViewData["Title"] = "📊 Dashboard";
}

<div class="container mt-5">

    <!-- HEADER -->
    <div class="dashboard-header mb-5 text-center">
        <h1 class="fw-bold">📊 Food Trends Dashboard</h1>
        <p class="text-muted">
            Real-time insights based on user reviews and restaurant activity.
        </p>
    </div>

    <!-- ROW 1 -->
    <div class="row g-4">

        <!-- BAR -->
        <div class="col-md-6">
            <div class="card dashboard-card p-4 shadow-sm">
                <h5 class="text-center mb-3">Top Restaurants (Avg Rating)</h5>
                <canvas id="barChart"></canvas>
            </div>
        </div>

        <!-- PIE -->
        <div class="col-md-6">
            <div class="card dashboard-card p-4 shadow-sm">
                <h5 class="text-center mb-3">Cuisine Popularity</h5>
                <canvas id="pieChart"></canvas>
            </div>
        </div>

    </div>

    <!-- ROW 2 -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card dashboard-card p-4 shadow-sm">
                <h5 class="text-center mb-3">Weekly Activity</h5>
                <canvas id="lineChart"></canvas>
            </div>
        </div>
    </div>

</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const restaurantData = @Html.Raw(JsonSerializer.Serialize(ViewBag.RestaurantRatings));
    const cuisineData = @Html.Raw(JsonSerializer.Serialize(ViewBag.CuisineData));

    // ✅ NEW: real labels + data
    const weeklyLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.WeeklyLabels));
    const weeklyData = @Html.Raw(JsonSerializer.Serialize(ViewBag.WeeklyData));

    // BRAND COLORS
    const brandColors = ["#ff7a18", "#ff3c6f", "#36A2EB", "#4CAF50"];

    // BAR
    new Chart(document.getElementById("barChart"), {
        type: "bar",
        data: {
            labels: restaurantData?.map(r => r.restaurant) || [],
            datasets: [{
                label: "Average Rating",
                data: restaurantData?.map(r => r.avgRating) || [],
                backgroundColor: brandColors[0]
            }]
        },
        options: {
            plugins: {
                legend: { display: false }
            }
        }
    });

    // PIE
    new Chart(document.getElementById("pieChart"), {
        type: "pie",
        data: {
            labels: cuisineData?.map(c => c.cuisine) || [],
            datasets: [{
                data: cuisineData?.map(c => c.count) || [],
                backgroundColor: brandColors
            }]
        }
    });

    // 🔥 LINE (UPDATED)
    new Chart(document.getElementById("lineChart"), {
        type: "line",
        data: {
            labels: weeklyLabels || [],
            datasets: [{
                label: "Reviews Over Time",
                data: weeklyData || [],
                borderColor: brandColors[1],
                backgroundColor: "rgba(255, 60, 111, 0.2)",
                fill: true,
                tension: 0.4,
                pointRadius: 5,
                pointBackgroundColor: brandColors[1]
            }]
        },
        options: {
            plugins: {
                legend: {
                    display: true
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                }
            }
        }
    });
</script>