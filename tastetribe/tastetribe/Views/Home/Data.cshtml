@*
    <h1>Data Page</h1>
*@
@{
}
<h1 class="text-center mt-4">📊 Food Trends Dashboard</h1>

<div class="container mt-5">

    <div class="row">
        <div class="col-md-6">
            <h4 class="text-center">Top Restaurants (Avg Rating)</h4>
            <canvas id="barChart"></canvas>
        </div>

        <div class="col-md-6">
            <h4 class="text-center">Cuisine Popularity</h4>
            <canvas id="pieChart"></canvas>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-12">
            <h4 class="text-center">Weekly Visits</h4>
            <canvas id="lineChart"></canvas>
        </div>
    </div>

</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // BAR CHART - Top Restaurants
    new Chart(document.getElementById("barChart"), {
        type: "bar",
        data: {
            labels: ["Chipotle", "Chick-fil-A", "Bento Cafe"],
            datasets: [{
                label: "Average Rating",
                data: [4.5, 4.7, 4.3],
                backgroundColor: ["#4CAF50", "#2196F3", "#FFC107"]
            }]
        }
    });

    // PIE CHART - Cuisine Popularity
    new Chart(document.getElementById("pieChart"), {
        type: "pie",
        data: {
            labels: ["Mexican", "American", "Asian"],
            datasets: [{
                data: [40, 35, 25],
                backgroundColor: ["#FF6384", "#36A2EB", "#FFCE56"]
            }]
        }
    });

    // LINE CHART - Weekly Visits
    new Chart(document.getElementById("lineChart"), {
        type: "line",
        data: {
            labels: ["Mon", "Tue", "Wed", "Thu", "Fri"],
            datasets: [{
                label: "Visits",
                data: [10, 15, 12, 20, 25],
                borderColor: "#4CAF50",
                fill: false
            }]
        }
    });
</script>