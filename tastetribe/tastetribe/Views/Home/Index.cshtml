@{
    ViewData["Title"] = "🍔 Taste Tribe";
}

<div class="text-center mt-5">

    <img src="/images/logo.png" style="max-width: 250px;" class="mb-3" />
    <p class="lead">Discover where your friends are eating and what dishes they love on campus.</p>

</div>

<hr />

<div class="container mt-4">

    <!-- HERO -->
    <div class="hero">
        <h1 class="display-4">🍔 Taste Tribe</h1>
        <p class="lead">Discover where your friends are eating and what dishes they love.</p>
    </div>

    <!-- ACTIVITY -->
    <div class="mt-5">
        <h3>🔍 Recent Activity</h3>

        <ul class="list-group">
            <li class="list-group-item">Alex ate Chicken Alfredo at Olive Garden ⭐ 4.5</li>
            <li class="list-group-item">Maria tried Sushi Roll at Bento Cafe 🍣</li>
            <li class="list-group-item">James had a Burrito at Chipotle 🌯</li>
        </ul>
    </div>

    <!-- ACTIONS -->
    <div class="mt-5">
        <h3>⚙️ Actions</h3>

        <div class="d-flex gap-2 flex-wrap mt-3">
            <a class="btn btn-brand" href="/Home/Create">Create</a>
            <a class="btn btn-primary" href="/Home/Read">Read</a>
            <a class="btn btn-warning" href="/Home/Update">Update</a>
            <a class="btn btn-danger" href="/Home/Delete">Delete</a>
        </div>
    </div>

</div>
