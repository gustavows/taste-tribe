@model IEnumerable<tastetribe.Models.Review>

@{
}

<h1 class="mt-4">📖 View Reviews</h1>

<p>List of reviews.</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-success">➕ New Review</a>
</p>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>ID</th>
            <th>User</th>
            <th>Restaurant</th>
            <th>Dish</th>
            <th>Rating</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.ReviewId</td>
            <td>@(r.User?.FirstName ?? "-")</td>
            <td>@(r.Restaurant?.Name ?? "-")</td>
            <td>@(r.Dish?.Name ?? "-")</td>
            <td>@r.Rating</td>
            <td>
                <a asp-action="Update" asp-route-id="@r.ReviewId" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="DeleteConfirmed" asp-route-id="@r.ReviewId" method="post" class="d-inline ms-2" onsubmit="return confirm('Delete this review?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@r.ReviewId" />
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
