@{
}

<h1 class="mt-4">✏️ Update Review</h1>

<p>This page simulates editing an existing review.</p>

<div class="card p-4 mt-3">
    <form>
        <div class="mb-3">
            <label class="form-label">Restaurant</label>
            <input type="text" class="form-control" value="Chipotle">
        </div>

        <div class="mb-3">
            <label class="form-label">Dish</label>
            <input type="text" class="form-control" value="Burrito">
        </div>

        <div class="mb-3">
            <label class="form-label">Rating</label>
            <input type="number" class="form-control" value="4">
        </div>

        <button class="btn btn-warning">Update (Simulation)</button>
    </form>
</div>
